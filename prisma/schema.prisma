generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum OrganizationStatus {
    DRAFT
    PUBLISHED
    ARCHIVED
}

enum SuggestionStatus {
    PENDING
    APPROVED
    REJECTED
}

enum SocialPlatform {
    FACEBOOK
    INSTAGRAM
    TIKTOK
    X
    LINKEDIN
    YOUTUBE
    OTHER
}

// ============================================================================
// MODELS
// ============================================================================

/// Organización principal (ONG, Asociación Civil, Proyecto Social)
model Organization {
    id               String             @id @default(cuid())
    slug             String             @unique
    name             String
    shortDescription String             @db.VarChar(160)
    fullDescription  String?            @db.Text
    logoUrl          String?
    coverImageUrl    String?
    status           OrganizationStatus @default(DRAFT)
    featured         Boolean            @default(false)
    verified         Boolean            @default(false)
    website          String?
    email            String
    phone            String?
    donationLink     String?

    // Gallery (4 image URLs)
    galleryImages String[]

    // Impact sidebar (progress bar)
    impactCurrent Int?
    impactGoal    Int?
    impactType    String?

    // Needs tab
    needs Json? // [{ category, title, description, urgency, quantity }]

    // Explore tab
    relevantLinks String[]

    // Impact tab (JSON fields — 1:1 with org)
    featuredFact   Json? // { value, unit, label, description, badge }
    secondaryFacts Json? // [{ value, unit, label, icon, color }]
    testimony      Json? // { quote, author, role, avatarUrl }
    milestone      Json? // { year, category, tagline, stats: [{ label, value }] }

    // Contact tab
    officeHours Json? // { monday: { open, close }, tuesday: ... , sunday: null }

    // Organization metadata
    foundedYear Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    location    Location?
    socialLinks SocialLink[]
    categories  Category[]

    @@index([slug])
    @@index([status])
    @@index([featured])
    @@index([verified])
}

/// Categoría/Taxonomía para clasificar organizaciones
model Category {
    id          String  @id @default(cuid())
    slug        String  @unique
    name        String
    description String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations (Many-to-Many)
    organizations Organization[]

    @@index([slug])
}

/// Ubicación de la organización (sede principal)
model Location {
    id            String  @id @default(cuid())
    city          String // Municipio/Delegación
    state         String // Estado
    googleMapsUrl String?
    latitude      Float?
    longitude     Float?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations (1-to-1)
    organizationId String       @unique
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// Enlaces a redes sociales de la organización
model SocialLink {
    id       String         @id @default(cuid())
    platform SocialPlatform
    url      String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations (Many-to-1)
    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    @@index([organizationId])
}

/// Log de auditoría para rastrear cambios
model AuditLog {
    id        String   @id @default(cuid())
    action    String // CREATE, UPDATE, DELETE, UPDATE_STATUS, DONATION_CLICK, etc.
    entityId  String // ID de la organización afectada
    details   Json? // Snapshot de cambios
    createdAt DateTime @default(now())

    @@index([entityId])
    @@index([createdAt])
}

/// Sugerencias de organizaciones enviadas por usuarios anónimos
model Suggestion {
    id          String           @id @default(cuid())
    orgName     String
    category    String           // slug de categoría sugerida
    location    String           // Ciudad / Estado (texto libre)
    description String           @db.Text
    url         String           // URL para verificación

    status      SuggestionStatus @default(PENDING)
    adminNotes  String?          @db.Text

    createdAt   DateTime         @default(now())
    reviewedAt  DateTime?

    @@index([status])
    @@index([createdAt])
}